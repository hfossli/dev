#!/usr/bin/env node

const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const { spawnSync } = require("node:child_process");

function usage() {
  console.log(`ios-sim-lease [options]

Creates (or reuses) a stable iOS simulator per worktree and prints its UDID.
Can also prune or release simulator lease claims.

Options:
  --cwd <path>           Resolve lease key from this directory (default: cwd)
  --owner-root <path>    Worktree root tied to this lease (used for stale pruning)
  --runtime <spec>       Runtime identifier or version (default: latest)
  --device-type <spec>   Device type identifier or name (default: preferred iPhone)
  --name-prefix <prefix> Simulator name prefix (default: ai-pranks-wt)
  --prune                Prune stale lease entries and exit
  --release              Release lease entries for --cwd and exit (also prunes)
  --verbose              Print diagnostics to stderr
  -h, --help             Show this help

Environment:
  IOS_SIM_RUNTIME        Same as --runtime
  IOS_SIM_DEVICE_TYPE    Same as --device-type
  IOS_SIM_NAME_PREFIX    Same as --name-prefix
`);
}

function parseArgs(argv) {
  const args = {
    mode: "lease",
    cwd: process.cwd(),
    ownerRoot: "",
    runtime: process.env.IOS_SIM_RUNTIME || "latest",
    deviceType: process.env.IOS_SIM_DEVICE_TYPE || "",
    namePrefix: process.env.IOS_SIM_NAME_PREFIX || "ai-pranks-wt",
    verbose: false,
  };

  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === "-h" || a === "--help") {
      usage();
      process.exit(0);
    }
    if (a === "--verbose") {
      args.verbose = true;
      continue;
    }
    if (a === "--prune") {
      if (args.mode !== "lease") {
        throw new Error("Only one of --prune or --release can be used at a time.");
      }
      args.mode = "prune";
      continue;
    }
    if (a === "--release") {
      if (args.mode !== "lease") {
        throw new Error("Only one of --prune or --release can be used at a time.");
      }
      args.mode = "release";
      continue;
    }
    if (a === "--boot" || a === "--focus") {
      throw new Error(
        `${a} is no longer supported here. Use ios-sim-boot to boot/focus a leased simulator.`
      );
    }
    if (a === "--cwd") {
      args.cwd = argv[++i];
      continue;
    }
    if (a === "--owner-root") {
      args.ownerRoot = argv[++i];
      continue;
    }
    if (a === "--runtime") {
      args.runtime = argv[++i];
      continue;
    }
    if (a === "--device-type") {
      args.deviceType = argv[++i];
      continue;
    }
    if (a === "--name-prefix") {
      args.namePrefix = argv[++i];
      continue;
    }
    throw new Error(`Unknown argument: ${a}`);
  }

  if (!args.cwd) throw new Error("Missing value for --cwd");
  if (args.mode === "lease" && !args.runtime) throw new Error("Missing value for --runtime");
  args.cwd = fs.realpathSync(args.cwd);
  if (args.ownerRoot) {
    args.ownerRoot = fs.realpathSync(args.ownerRoot);
  }
  return args;
}

function run(cmd, cmdArgs, opts = {}) {
  const r = spawnSync(cmd, cmdArgs, {
    encoding: "utf8",
    stdio: ["ignore", "pipe", "pipe"],
  });
  if (r.error) throw r.error;
  if (r.status !== 0 && !opts.allowFailure) {
    const stderr = (r.stderr || "").trim();
    const stdout = (r.stdout || "").trim();
    const details = stderr || stdout || `exit code ${r.status}`;
    throw new Error(`${cmd} ${cmdArgs.join(" ")} failed: ${details}`);
  }
  return {
    status: r.status,
    stdout: (r.stdout || "").trim(),
    stderr: (r.stderr || "").trim(),
  };
}

function runJson(args) {
  const out = run("xcrun", args).stdout;
  return JSON.parse(out);
}

function isRuntimeAvailable(runtime) {
  if (runtime.isAvailable === false) return false;
  if (typeof runtime.availability === "string") {
    if (runtime.availability.toLowerCase().includes("unavailable")) return false;
  }
  if (runtime.availabilityError) return false;
  return true;
}

function parseVersion(version) {
  if (!version || typeof version !== "string") return [];
  return version
    .split(".")
    .map((part) => Number(part))
    .filter((n) => Number.isFinite(n));
}

function cmpVersionDesc(a, b) {
  const av = parseVersion(a);
  const bv = parseVersion(b);
  const len = Math.max(av.length, bv.length);
  for (let i = 0; i < len; i++) {
    const an = av[i] || 0;
    const bn = bv[i] || 0;
    if (an !== bn) return bn - an;
  }
  return 0;
}

function normalizeVersionSpec(spec) {
  return spec.replace(/^ios[\s-]*/i, "").trim();
}

function selectRuntime(runtimes, spec) {
  const iosRuntimes = runtimes.filter(
    (r) => r.identifier && r.identifier.includes(".SimRuntime.iOS-") && isRuntimeAvailable(r)
  );
  if (iosRuntimes.length === 0) {
    throw new Error(
      "No available iOS runtimes found. Install one in Xcode > Settings > Platforms."
    );
  }

  if (!spec || spec === "latest") {
    return [...iosRuntimes].sort((a, b) => {
      const byVersion = cmpVersionDesc(a.version, b.version);
      if (byVersion !== 0) return byVersion;
      return String(a.identifier).localeCompare(String(b.identifier));
    })[0];
  }

  if (spec.startsWith("com.apple.CoreSimulator.SimRuntime.")) {
    const exact = iosRuntimes.find((r) => r.identifier === spec);
    if (exact) return exact;
    throw new Error(`Requested runtime not installed or unavailable: ${spec}`);
  }

  const v = normalizeVersionSpec(spec);
  const dashed = v.replace(/\./g, "-");
  const byVersion = iosRuntimes.find((r) => r.version === v);
  if (byVersion) return byVersion;

  const byIdentifier = iosRuntimes.find((r) => r.identifier.endsWith(`iOS-${dashed}`));
  if (byIdentifier) return byIdentifier;

  const byName = iosRuntimes.find(
    (r) => String(r.name || "").toLowerCase() === `ios ${v}`.toLowerCase()
  );
  if (byName) return byName;

  const available = iosRuntimes.map((r) => `${r.version} (${r.identifier})`).join(", ");
  throw new Error(`Runtime "${spec}" not found. Available: ${available}`);
}

function selectDeviceType(deviceTypes, spec) {
  if (spec) {
    if (spec.startsWith("com.apple.CoreSimulator.SimDeviceType.")) {
      const exactById = deviceTypes.find((d) => d.identifier === spec);
      if (exactById) return exactById;
      throw new Error(`Device type identifier not found: ${spec}`);
    }

    const lower = spec.toLowerCase();
    const exactByName = deviceTypes.find((d) => String(d.name || "").toLowerCase() === lower);
    if (exactByName) return exactByName;

    const fuzzy = deviceTypes.find((d) =>
      String(d.name || "")
        .toLowerCase()
        .includes(lower)
    );
    if (fuzzy) return fuzzy;

    throw new Error(`Device type not found: ${spec}`);
  }

  const preferred = [
    "iPhone 16",
    "iPhone 16 Pro",
    "iPhone 15",
    "iPhone 15 Pro",
    "iPhone 14",
    "iPhone SE (3rd generation)",
  ];
  for (const name of preferred) {
    const match = deviceTypes.find((d) => d.name === name);
    if (match) return match;
  }

  const anyIphone = deviceTypes.find((d) => String(d.name || "").startsWith("iPhone"));
  if (anyIphone) return anyIphone;

  if (deviceTypes.length === 0) {
    throw new Error("No simulator device types found.");
  }
  return deviceTypes[0];
}

function slugify(s) {
  return String(s)
    .replace(/[^a-zA-Z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "")
    .toLowerCase();
}

function sessionNameLikePath(rootPath) {
  return String(rootPath)
    .replace(/^\/+/, "")
    .replace(/[^a-zA-Z0-9]/g, "-");
}

function getWorktreeRoot(cwd) {
  const gitRoot = run("git", ["-C", cwd, "rev-parse", "--show-toplevel"], { allowFailure: true });
  if (gitRoot.status === 0 && gitRoot.stdout) return fs.realpathSync(gitRoot.stdout);
  return cwd;
}

function parseGitWorktreePorcelain(text) {
  const lines = String(text || "").split(/\r?\n/);
  const entries = [];
  let current = null;

  const flush = () => {
    if (current && current.path) entries.push(current);
    current = null;
  };

  for (const line of lines) {
    if (!line.trim()) {
      flush();
      continue;
    }

    const separator = line.indexOf(" ");
    const key = separator === -1 ? line : line.slice(0, separator);
    const value = separator === -1 ? "" : line.slice(separator + 1);

    if (key === "worktree") {
      flush();
      current = { path: value };
      continue;
    }
    if (!current) continue;
    if (key === "branch") current.branch = value;
    else if (key === "HEAD") current.head = value;
    else if (key === "detached") current.detached = true;
    else if (key === "locked") current.locked = value || true;
    else if (key === "prunable") current.prunable = value || true;
  }

  flush();
  return entries;
}

function listGitWorktreeRoots(cwd) {
  const root = getWorktreeRoot(cwd);
  const listed = run("git", ["-C", root, "worktree", "list", "--porcelain"], {
    allowFailure: true,
  });
  if (listed.status !== 0 || !listed.stdout) return null;

  const roots = new Set();
  for (const entry of parseGitWorktreePorcelain(listed.stdout)) {
    if (!entry.path) continue;
    try {
      roots.add(fs.realpathSync(entry.path));
    } catch {
      roots.add(path.resolve(entry.path));
    }
  }
  return roots.size > 0 ? roots : null;
}

function rootTokenFromPath(rootPath) {
  return String(rootPath || "")
    .replace(/^\/+/, "")
    .replace(/[^a-zA-Z0-9]/g, "-")
    .replace(/^-+|-+$/g, "");
}

function anchorRootTokenFromPath(dirPath) {
  const marker = `${path.sep}dev-session-anchors${path.sep}`;
  const value = String(dirPath || "");
  const markerIndex = value.indexOf(marker);
  if (markerIndex === -1) return "";
  const remainder = value.slice(markerIndex + marker.length);
  const token = remainder.split(path.sep)[0];
  return token || "";
}

function deviceIsAvailable(device) {
  return !device ? false : device.isAvailable !== false;
}

function isManagedSimulatorName(name) {
  const value = String(name || "");
  return value.startsWith("ai-pranks-") && value.includes("-ios-");
}

function isUuidLike(value) {
  return /^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$/.test(
    String(value || "")
  );
}

function getUdidFromDeviceDirectoryName(name) {
  const value = String(name || "");
  if (isUuidLike(value)) return value.toUpperCase();
  const deletingMatch = /^Deleting-([0-9A-Fa-f-]+)$/.exec(value);
  if (deletingMatch && isUuidLike(deletingMatch[1])) {
    return deletingMatch[1].toUpperCase();
  }
  return "";
}

function pruneOrphanDeviceDirectories(index, verbose) {
  const devicesDir = path.join(os.homedir(), "Library", "Developer", "CoreSimulator", "Devices");
  if (!fs.existsSync(devicesDir)) return { removedCount: 0 };

  const knownUdids =
    index && index.byUdid instanceof Map ? new Set(index.byUdid.keys()) : new Set();
  let removedCount = 0;

  for (const entry of fs.readdirSync(devicesDir, { withFileTypes: true })) {
    if (!entry.isDirectory()) continue;
    const udid = getUdidFromDeviceDirectoryName(entry.name);
    if (!udid) continue;
    if (knownUdids.has(udid)) continue;

    const dirPath = path.join(devicesDir, entry.name);
    const plistPath = path.join(dirPath, "device.plist");
    if (fs.existsSync(plistPath)) continue;

    try {
      fs.rmSync(dirPath, { recursive: true, force: true });
      removedCount++;
      log(verbose, `Removed orphan simulator directory ${entry.name}`);
    } catch (err) {
      log(verbose, `Failed to remove orphan simulator directory ${entry.name}: ${err.message}`);
    }
  }

  return { removedCount };
}

function buildDeviceIndex(devicesJson) {
  const byUdid = new Map();
  const allByRuntime = new Map();
  for (const [runtimeId, devices] of Object.entries(devicesJson.devices || {})) {
    const list = Array.isArray(devices) ? devices : [];
    allByRuntime.set(runtimeId, list);
    for (const device of list) {
      byUdid.set(device.udid, { runtimeId, device });
    }
  }
  return { byUdid, allByRuntime };
}

function selectRuntimeDefaultDeviceType(allByRuntime, runtimeId, allDeviceTypes) {
  const devicesForRuntime = allByRuntime.get(runtimeId) || [];
  const preferredDevice = devicesForRuntime.find(
    (d) =>
      deviceIsAvailable(d) && String(d.name || "").startsWith("iPhone") && d.deviceTypeIdentifier
  );
  if (!preferredDevice) return null;
  return allDeviceTypes.find((t) => t.identifier === preferredDevice.deviceTypeIdentifier) || null;
}

function getCachePaths() {
  const cacheDir = path.join(os.homedir(), ".cache", "ios-sim-lease");
  return {
    cacheDir,
    leaseFile: path.join(cacheDir, "leases.json"),
    lockFile: path.join(cacheDir, "leases.lock"),
  };
}

function isProcessAlive(pid) {
  try {
    process.kill(pid, 0);
    return true;
  } catch {
    return false;
  }
}

function sleepSync(ms) {
  const end = Date.now() + ms;
  while (Date.now() < end) {}
}

function acquireLock(lockFile) {
  fs.mkdirSync(path.dirname(lockFile), { recursive: true });
  const maxAttempts = 50;
  const retryDelayMs = 100;
  for (let i = 0; i < maxAttempts; i++) {
    try {
      const fd = fs.openSync(lockFile, "wx");
      fs.writeFileSync(fd, String(process.pid));
      fs.closeSync(fd);
      return;
    } catch (err) {
      if (err.code !== "EEXIST") throw err;
      try {
        const pid = Number(fs.readFileSync(lockFile, "utf8").trim());
        if (pid && !isProcessAlive(pid)) {
          fs.unlinkSync(lockFile);
          continue;
        }
      } catch {
        continue;
      }
      sleepSync(retryDelayMs);
    }
  }
  throw new Error("Could not acquire ios-sim-lease lock");
}

function releaseLock(lockFile) {
  try {
    fs.unlinkSync(lockFile);
  } catch {}
}

function readLeases(leaseFile) {
  try {
    return JSON.parse(fs.readFileSync(leaseFile, "utf8"));
  } catch {
    return { leases: {} };
  }
}

function writeLeases(leaseFile, data) {
  fs.mkdirSync(path.dirname(leaseFile), { recursive: true });
  fs.writeFileSync(leaseFile, JSON.stringify(data, null, 2) + "\n");
}

function leaseRootFromKey(key) {
  if (typeof key !== "string") return "";
  const [root] = key.split("\t");
  return root || "";
}

function getLeaseStalePath(lease, key) {
  if (!lease || typeof lease !== "object") return "";
  const ownerRoot = typeof lease.ownerRoot === "string" && lease.ownerRoot ? lease.ownerRoot : "";
  if (ownerRoot) return ownerRoot;

  const cwd = typeof lease.cwd === "string" && lease.cwd ? lease.cwd : leaseRootFromKey(key);
  return cwd || "";
}

function createSimulatorName(prefix, worktreeRoot, runtime) {
  const sessionLike = sessionNameLikePath(worktreeRoot) || "worktree";
  const runtimeSlug = slugify(
    runtime.version || runtime.identifier.replace(/^.*iOS-/, "").replace(/-/g, ".")
  );
  const prefixSlug = slugify(prefix) || "sim";
  const suffix = `-ios-${runtimeSlug}`;
  const maxLen = 80;
  const maxBodyLen = Math.max(1, maxLen - prefixSlug.length - suffix.length - 1);
  const body = sessionLike.slice(0, maxBodyLen);
  return `${prefixSlug}-${body}${suffix}`;
}

function log(verbose, message) {
  if (verbose) process.stderr.write(`[ios-sim-lease] ${message}\n`);
}

function pruneLeases(data, index, verbose, context = {}) {
  const activeWorktreeRoots =
    context.activeWorktreeRoots instanceof Set ? context.activeWorktreeRoots : null;
  const activeWorktreeTokens =
    context.activeWorktreeTokens instanceof Set ? context.activeWorktreeTokens : null;
  const next = { leases: {} };
  const pruned = [];

  for (const [key, lease] of Object.entries(data.leases || {})) {
    if (!lease || typeof lease !== "object") {
      pruned.push({ key, reason: "invalid lease entry", udid: "" });
      continue;
    }

    const cwd = typeof lease.cwd === "string" && lease.cwd ? lease.cwd : leaseRootFromKey(key);
    const ownerRoot = typeof lease.ownerRoot === "string" && lease.ownerRoot ? lease.ownerRoot : "";
    const stalePath = getLeaseStalePath(lease, key);
    const udid = typeof lease.udid === "string" ? lease.udid : "";
    const leased = udid ? index.byUdid.get(udid) : null;

    if (
      ownerRoot &&
      fs.existsSync(ownerRoot) &&
      activeWorktreeRoots &&
      activeWorktreeRoots.size > 0
    ) {
      const realOwnerRoot = fs.realpathSync(ownerRoot);
      if (!activeWorktreeRoots.has(realOwnerRoot)) {
        pruned.push({ key, reason: `stale worktree root (${ownerRoot})`, udid });
        continue;
      }
    }
    if (!ownerRoot && activeWorktreeTokens && activeWorktreeTokens.size > 0) {
      const rootToken = anchorRootTokenFromPath(cwd);
      if (rootToken && !activeWorktreeTokens.has(rootToken)) {
        pruned.push({ key, reason: `stale worktree token (${rootToken})`, udid });
        continue;
      }
    }
    if (!stalePath || !fs.existsSync(stalePath)) {
      pruned.push({ key, reason: `stale worktree path (${stalePath || "unknown"})`, udid });
      continue;
    }
    if (!udid) {
      pruned.push({ key, reason: "missing simulator UDID", udid: "" });
      continue;
    }
    if (!leased) {
      pruned.push({ key, reason: `simulator missing (${udid})`, udid });
      continue;
    }
    if (!deviceIsAvailable(leased.device)) {
      pruned.push({ key, reason: `simulator unavailable (${udid})`, udid });
      continue;
    }

    next.leases[key] = {
      ...lease,
      cwd,
      ...(ownerRoot ? { ownerRoot } : {}),
    };
  }

  const keptUdids = new Set(
    Object.values(next.leases)
      .map((lease) => (lease && typeof lease.udid === "string" ? lease.udid : ""))
      .filter(Boolean)
  );

  let deletedSimulator = false;
  const deletedUdids = new Set();
  for (const entry of pruned) {
    log(verbose, `Pruned lease ${entry.key}: ${entry.reason}`);
    if (!entry.udid || keptUdids.has(entry.udid)) continue;

    const shouldDeleteDevice =
      entry.reason.startsWith("stale worktree") || entry.reason.startsWith("simulator unavailable");
    if (!shouldDeleteDevice) continue;

    if (deletedUdids.has(entry.udid)) continue;
    if (!index.byUdid.has(entry.udid)) continue;
    log(verbose, `Deleting dangling simulator ${entry.udid}`);
    run("xcrun", ["simctl", "delete", entry.udid], { allowFailure: true });
    deletedSimulator = true;
    deletedUdids.add(entry.udid);
  }

  for (const [udid, leased] of index.byUdid.entries()) {
    if (keptUdids.has(udid)) continue;
    if (deletedUdids.has(udid)) continue;
    const device = leased && leased.device ? leased.device : null;
    if (!device || !isManagedSimulatorName(device.name)) continue;
    if (String(device.state || "").toLowerCase() === "booted") continue;
    log(verbose, `Deleting unleased managed simulator ${device.name} (${udid})`);
    run("xcrun", ["simctl", "delete", udid], { allowFailure: true });
    deletedSimulator = true;
    deletedUdids.add(udid);
  }

  return {
    leases: next.leases,
    deletedSimulator,
  };
}

function releaseLeases(data, index, { leaseRoot, verbose }) {
  const next = { leases: {} };
  const released = [];

  for (const [key, lease] of Object.entries(data.leases || {})) {
    if (leaseRootFromKey(key) === leaseRoot) {
      released.push({ key, lease });
      continue;
    }
    next.leases[key] = lease;
  }

  if (released.length === 0) {
    log(verbose, `No leases to release for ${leaseRoot}`);
    return {
      leases: next.leases,
      deletedSimulator: false,
      releasedCount: 0,
    };
  }

  const keptUdids = new Set(
    Object.values(next.leases)
      .map((lease) => (lease && typeof lease.udid === "string" ? lease.udid : ""))
      .filter(Boolean)
  );

  let deletedSimulator = false;
  for (const entry of released) {
    const udid = entry.lease && typeof entry.lease.udid === "string" ? entry.lease.udid : "";
    if (!udid || keptUdids.has(udid)) continue;
    if (!index.byUdid.has(udid)) continue;
    log(verbose, `Deleting released simulator ${udid}`);
    run("xcrun", ["simctl", "delete", udid], { allowFailure: true });
    deletedSimulator = true;
  }

  log(verbose, `Released ${released.length} lease(s) for ${leaseRoot}`);

  return {
    leases: next.leases,
    deletedSimulator,
    releasedCount: released.length,
  };
}

function main() {
  if (process.platform !== "darwin") {
    throw new Error("ios-sim-lease only supports macOS.");
  }
  const args = parseArgs(process.argv.slice(2));

  run("xcrun", ["simctl", "help"]);

  const { leaseFile, lockFile } = getCachePaths();
  acquireLock(lockFile);
  try {
    const data = readLeases(leaseFile);
    if (!data.leases || typeof data.leases !== "object") data.leases = {};

    let devicesJson = runJson(["simctl", "list", "devices", "--json"]);
    let index = buildDeviceIndex(devicesJson);

    const activeWorktreeRoots = listGitWorktreeRoots(args.cwd);
    const activeWorktreeTokens = activeWorktreeRoots
      ? new Set([...activeWorktreeRoots].map(rootTokenFromPath).filter(Boolean))
      : null;

    if (args.mode !== "lease") {
      const pruned = pruneLeases(data, index, args.verbose, {
        activeWorktreeRoots,
        activeWorktreeTokens,
      });
      data.leases = pruned.leases;
      if (pruned.deletedSimulator) {
        devicesJson = runJson(["simctl", "list", "devices", "--json"]);
        index = buildDeviceIndex(devicesJson);
      }
      const orphanDirectories = pruneOrphanDeviceDirectories(index, args.verbose);
      if (orphanDirectories.removedCount > 0) {
        log(args.verbose, `Removed ${orphanDirectories.removedCount} orphan simulator directories`);
      }
    }

    if (args.mode === "prune") {
      writeLeases(leaseFile, data);
      return;
    }

    if (args.mode === "release") {
      const leaseRoot = getWorktreeRoot(args.cwd);
      const released = releaseLeases(data, index, {
        leaseRoot,
        verbose: args.verbose,
      });
      data.leases = released.leases;
      writeLeases(leaseFile, data);
      return;
    }

    const runtimesJson = runJson(["simctl", "list", "runtimes", "--json"]);
    const runtime = selectRuntime(runtimesJson.runtimes || [], args.runtime);

    const deviceTypesJson = runJson(["simctl", "list", "devicetypes", "--json"]);
    const allDeviceTypes = deviceTypesJson.devicetypes || [];
    const runtimeDefaultDeviceType = selectRuntimeDefaultDeviceType(
      index.allByRuntime,
      runtime.identifier,
      allDeviceTypes
    );
    const selectedDeviceType = args.deviceType
      ? selectDeviceType(allDeviceTypes, args.deviceType)
      : runtimeDefaultDeviceType || selectDeviceType(allDeviceTypes, "");

    const worktreeRoot = getWorktreeRoot(args.cwd);
    const simulatorName = createSimulatorName(args.namePrefix, worktreeRoot, runtime);
    const leaseKey = `${worktreeRoot}\t${runtime.identifier}\t${selectedDeviceType.identifier}`;

    let udid = "";
    const existingLease = data.leases[leaseKey];
    if (existingLease && existingLease.udid) {
      const leased = index.byUdid.get(existingLease.udid);
      if (leased && leased.runtimeId === runtime.identifier && deviceIsAvailable(leased.device)) {
        udid = existingLease.udid;
        log(args.verbose, `Reusing leased simulator ${existingLease.name} (${udid})`);
      } else {
        delete data.leases[leaseKey];
      }
    }

    if (!udid) {
      const devicesForRuntime = index.allByRuntime.get(runtime.identifier) || [];
      const byName = devicesForRuntime.find(
        (d) =>
          d.name === simulatorName &&
          d.deviceTypeIdentifier === selectedDeviceType.identifier &&
          deviceIsAvailable(d)
      );
      if (byName) {
        udid = byName.udid;
        log(args.verbose, `Reusing simulator by name ${simulatorName} (${udid})`);
      }
    }

    if (!udid) {
      log(
        args.verbose,
        `Creating simulator "${simulatorName}" with ${selectedDeviceType.identifier} on ${runtime.identifier}`
      );
      udid = run("xcrun", [
        "simctl",
        "create",
        simulatorName,
        selectedDeviceType.identifier,
        runtime.identifier,
      ]).stdout;
    }

    data.leases[leaseKey] = {
      cwd: worktreeRoot,
      ...(args.ownerRoot ? { ownerRoot: args.ownerRoot } : {}),
      runtime: runtime.identifier,
      runtimeVersion: runtime.version,
      deviceType: selectedDeviceType.identifier,
      name: simulatorName,
      udid,
      updatedAt: new Date().toISOString(),
    };
    writeLeases(leaseFile, data);

    process.stdout.write(`${udid}\n`);
  } finally {
    releaseLock(lockFile);
  }
}

try {
  main();
} catch (err) {
  process.stderr.write(`ios-sim-lease: ${err.message || String(err)}\n`);
  process.exit(1);
}
