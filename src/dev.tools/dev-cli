#!/usr/bin/env node

const fs = require("node:fs");
const path = require("node:path");
const { createRequire } = require("node:module");
const { pathToFileURL } = require("node:url");
const { die, run, sessionName: sessionNameFromPath, getWorktreeRoot } = require("./dev-tools.js");

function shellQuote(value) {
  return `'${String(value).replace(/'/g, `'\"'\"'`)}'`;
}

function withInheritedPath(command) {
  const inheritedPath = String(process.env.PATH || "");
  if (!inheritedPath) return String(command || "");
  return `export PATH=${shellQuote(inheritedPath)}; ${command}`;
}

function formatAvailableEntries(entries = []) {
  if (!entries || entries.length === 0) return ["  (none)"];
  return entries.map((entry) =>
    entry.description ? `  ${entry.name}: ${entry.description}` : `  ${entry.name}`
  );
}

function usage(appEntries = [], toolEntries = []) {
  const appLines = formatAvailableEntries(appEntries);
  const toolLines = formatAvailableEntries(toolEntries);
  return [
    "Usage:",
    "  ./dev start <app> [--attach|--split-attach] [--lines <n>]",
    "  ./dev restart <app|all> [--attach|--split-attach] [--lines <n>]",
    "  ./dev stop <app|all>",
    "  ./dev attach",
    "  ./dev logs <app> [--lines <n>]",
    "  ./dev tail <app> [--lines <n>] [--until-marker <text>] [--until-timeout <seconds>]",
    "  ./dev split-attach [--lines <n>]",
    "  ./dev tool <tool-name> [tool args...]",
    "",
    "Available apps:",
    ...appLines,
    "",
    "Available tools:",
    ...toolLines,
    "",
    "Examples:",
    "  ./dev start api",
    "  ./dev start api --attach",
    "  ./dev start api --split-attach --lines 200",
    "  ./dev restart api",
    "  ./dev restart api --attach",
    "  ./dev restart all --split-attach",
    "  ./dev stop api",
    "  ./dev stop all",
    "  ./dev attach",
    "  ./dev logs api --lines 250",
    "  ./dev tail admin",
    "  ./dev tail api --until-marker READY --until-timeout 30",
    "  ./dev split-attach",
    "  ./dev tool axe tap --id onboarding.get_started_button",
    '  ./dev tool axe tap --label "Continue"',
    "  ./dev start admin",
  ].join("\n");
}

function parseArgs(argv) {
  const positional = [];
  let linesOverride = null;
  let untilMarker = null;
  let untilTimeoutSeconds = null;
  let attachRequested = false;
  let splitAttachRequested = false;
  let help = false;

  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];
    const command = positional[0] || "";

    if (command === "tool") {
      positional.push(arg);
      continue;
    }

    if (arg === "-h" || arg === "--help") {
      help = true;
      continue;
    }
    if (arg === "--attach") {
      attachRequested = true;
      continue;
    }
    if (arg === "--split-attach") {
      splitAttachRequested = true;
      continue;
    }
    if (arg === "--lines") {
      const value = argv[i + 1];
      if (!value || value.startsWith("-")) {
        die("Error: --lines requires a positive integer value.");
      }
      const parsed = Number.parseInt(value, 10);
      if (!Number.isInteger(parsed) || parsed <= 0) {
        die("Error: --lines requires a positive integer value.");
      }
      linesOverride = parsed;
      i++;
      continue;
    }
    if (arg.startsWith("--lines=")) {
      const value = arg.slice("--lines=".length);
      const parsed = Number.parseInt(value, 10);
      if (!value || !Number.isInteger(parsed) || parsed <= 0) {
        die("Error: --lines requires a positive integer value.");
      }
      linesOverride = parsed;
      continue;
    }
    if (arg === "--until-marker") {
      const value = argv[i + 1];
      if (!value || value.startsWith("-")) {
        die("Error: --until-marker requires a non-empty value.");
      }
      untilMarker = value;
      i++;
      continue;
    }
    if (arg.startsWith("--until-marker=")) {
      const value = arg.slice("--until-marker=".length);
      if (!value) {
        die("Error: --until-marker requires a non-empty value.");
      }
      untilMarker = value;
      continue;
    }
    if (arg === "--until-timeout") {
      const value = argv[i + 1];
      if (!value || value.startsWith("-")) {
        die("Error: --until-timeout requires a positive number of seconds.");
      }
      const parsed = Number(value);
      if (!Number.isFinite(parsed) || parsed <= 0) {
        die("Error: --until-timeout requires a positive number of seconds.");
      }
      untilTimeoutSeconds = parsed;
      i++;
      continue;
    }
    if (arg.startsWith("--until-timeout=")) {
      const value = arg.slice("--until-timeout=".length);
      const parsed = Number(value);
      if (!value || !Number.isFinite(parsed) || parsed <= 0) {
        die("Error: --until-timeout requires a positive number of seconds.");
      }
      untilTimeoutSeconds = parsed;
      continue;
    }
    if (arg.startsWith("-")) die(`Error: unknown option "${arg}"`);
    positional.push(arg);
  }

  const command = positional[0] || "";
  if (command !== "tool" && positional.length > 2) {
    die(`Error: unexpected argument "${positional[2]}"`);
  }

  return {
    help,
    command,
    app: positional[1] || "",
    commandArgs: command === "tool" ? positional.slice(2) : [],
    linesOverride,
    untilMarker,
    untilTimeoutSeconds,
    attachRequested,
    splitAttachRequested,
  };
}

function loadAppsModuleFromTranspiledDefault(configPath, sourceCode) {
  const transformed = sourceCode.replace(/\bexport\s+default\b/, "module.exports.default =");
  if (transformed === sourceCode) {
    throw new Error(`failed to load ${configPath}: missing supported exports`);
  }

  const moduleObj = { exports: {} };
  const localRequire = createRequire(configPath);
  const dirname = path.dirname(configPath);
  const runner = new Function(
    "require",
    "module",
    "exports",
    "__filename",
    "__dirname",
    transformed
  );
  runner(localRequire, moduleObj, moduleObj.exports, configPath, dirname);
  return moduleObj.exports;
}

async function loadAppsModule(root) {
  const configPath = path.join(root, "dev.config.js");
  let loaded;

  try {
    loaded = require(configPath);
  } catch (requireError) {
    try {
      const imported = await import(pathToFileURL(configPath).href);
      loaded = imported;
    } catch (importError) {
      try {
        const sourceCode = fs.readFileSync(configPath, "utf8");
        loaded = loadAppsModuleFromTranspiledDefault(configPath, sourceCode);
      } catch (transpileError) {
        const detail =
          transpileError && transpileError.message
            ? transpileError.message
            : importError && importError.message
              ? importError.message
              : requireError.message;
        die(`Error: failed to load ${configPath}: ${detail}`);
      }
    }
  }

  if (!loaded || typeof loaded !== "object") {
    die(`Error: ${configPath} must export an object.`);
  }

  return { loaded, configPath };
}

function getConfigFactory(loaded, configPath) {
  const fromModuleConfig = loaded && typeof loaded.config === "function" ? loaded.config : null;
  const fromModuleDefault = loaded && typeof loaded.default === "function" ? loaded.default : null;
  const fromDefaultConfig =
    loaded && loaded.default && typeof loaded.default.config === "function"
      ? loaded.default.config
      : null;

  const configFactory = fromModuleConfig || fromModuleDefault || fromDefaultConfig;
  if (!configFactory) {
    die(`Error: ${configPath} must export config(session) or default config(session).`);
  }
  return configFactory;
}

function resolveRuntimeConfig(configFactory, configPath, sessionId) {
  const cfg = configFactory(sessionId);
  if (!cfg || typeof cfg !== "object") {
    die(`Error: config(session) in ${configPath} must return an object.`);
  }
  if (!cfg.apps || typeof cfg.apps !== "object") {
    die(`Error: config(session) in ${configPath} must return an apps object.`);
  }
  return cfg;
}

function resolveStartCommand(appName, appDef) {
  if (typeof appDef === "string") return appDef;
  if (!appDef || typeof appDef !== "object") {
    die(`Error: app "${appName}" must be a string command or an object with start.`);
  }

  const { start } = appDef;
  if (typeof start === "string") return start;
  if (typeof start === "function") {
    const command = start();
    if (typeof command !== "string" || !command.trim()) {
      die(`Error: app "${appName}" start() must return a non-empty string.`);
    }
    return command;
  }

  die(`Error: app "${appName}" must define start as a string or function.`);
}

function getItemDescription(itemDef) {
  if (!itemDef || typeof itemDef !== "object") return "";
  if (typeof itemDef.description !== "string") return "";
  return itemDef.description.trim();
}

function resolveToolCommand(toolName, toolDef, toolArgs) {
  let executableDef = toolDef;
  if (
    toolDef &&
    typeof toolDef === "object" &&
    (typeof toolDef.run === "function" || typeof toolDef.run === "string")
  ) {
    executableDef = toolDef.run;
  }

  if (typeof executableDef === "string") return executableDef;
  if (typeof executableDef === "function") {
    const quotedArgs = toolArgs.map((arg) => shellQuote(arg)).join(" ");
    const plainArgs = toolArgs.join(" ");
    const command = executableDef(quotedArgs, toolArgs, plainArgs);
    if (typeof command !== "string" || !command.trim()) {
      die(`Error: tool "${toolName}" must return a non-empty command string.`);
    }
    return command;
  }
  die(`Error: tool "${toolName}" must be a string/function or an object with run.`);
}

function ensureTmuxInstalled() {
  const probe = run("tmux", ["-V"], { allowFailure: true });
  if (probe.status !== 0) die("Error: tmux is required but was not found in PATH.");
}

function tmuxSessionExists(tmuxSession) {
  return run("tmux", ["has-session", "-t", tmuxSession], { allowFailure: true }).status === 0;
}

function tmuxWindowExists(tmuxSession, windowName) {
  const listed = run("tmux", ["list-windows", "-t", tmuxSession, "-F", "#{window_name}"], {
    allowFailure: true,
  });
  if (listed.status !== 0) return false;
  const windows = listed.stdout
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean);
  return windows.includes(windowName);
}

function resolveLineCount(linesOverride) {
  if (Number.isInteger(linesOverride) && linesOverride > 0) return linesOverride;
  const fromEnv = Number.parseInt(String(process.env.TAIL_LINES || ""), 10);
  if (Number.isInteger(fromEnv) && fromEnv > 0) return fromEnv;
  return 120;
}

function captureWindowLogs(tmuxSession, appName, lines) {
  const captured = run(
    "tmux",
    ["capture-pane", "-p", "-J", "-S", `-${lines}`, "-t", `${tmuxSession}:${appName}`],
    { allowFailure: true }
  );
  if (captured.status !== 0) {
    const detail = captured.stderr || captured.stdout || `exit code ${captured.status}`;
    throw new Error(`failed to capture logs for "${appName}" in "${tmuxSession}": ${detail}`);
  }
  return captured.stdout;
}

function getOverlapCount(previousLines, nextLines) {
  const maxOverlap = Math.min(previousLines.length, nextLines.length);
  for (let overlap = maxOverlap; overlap >= 0; overlap--) {
    let equal = true;
    for (let i = 0; i < overlap; i++) {
      if (previousLines[previousLines.length - overlap + i] !== nextLines[i]) {
        equal = false;
        break;
      }
    }
    if (equal) return overlap;
  }
  return 0;
}

function ensureAppTarget({ appName, apps, usageText, tmuxSession }) {
  if (!appName) {
    process.stderr.write(`${usageText}\n`);
    process.exit(2);
  }

  if (!Object.prototype.hasOwnProperty.call(apps, appName)) {
    dieWithUsage(`Error: unknown app "${appName}"`, usageText);
  }

  ensureTmuxInstalled();

  if (!tmuxSessionExists(tmuxSession)) {
    die(`Error: session "${tmuxSession}" does not exist.`);
  }

  if (!tmuxWindowExists(tmuxSession, appName)) {
    die(`Error: window "${appName}" does not exist in session "${tmuxSession}".`);
  }
}

function buildTailPaneCommand({ root, sessionOverride, appName, lines }) {
  const scriptPath = path.join(root, "dev.tools", "dev-cli");
  const sessionArg = sessionOverride ? ` --session ${shellQuote(sessionOverride)}` : "";
  return (
    `cd ${shellQuote(root)} && ` +
    `node ${shellQuote(scriptPath)} tail ${shellQuote(appName)}${sessionArg} --lines ${lines}`
  );
}

function openSplitAttachWindow({ root, sessionOverride, tmuxSession, appNames, lines }) {
  const splitWindowName = "split-attach";
  const activeApps = appNames.filter((appName) => tmuxWindowExists(tmuxSession, appName));
  if (activeApps.length === 0) {
    die(`Error: no active app windows found in session "${tmuxSession}".`);
  }

  if (tmuxWindowExists(tmuxSession, splitWindowName)) {
    run("tmux", ["kill-window", "-t", `${tmuxSession}:${splitWindowName}`], {
      allowFailure: true,
    });
  }

  const [firstApp, ...restApps] = activeApps;
  run("tmux", [
    "new-window",
    "-d",
    "-t",
    tmuxSession,
    "-n",
    splitWindowName,
    buildTailPaneCommand({ root, sessionOverride, appName: firstApp, lines }),
  ]);

  for (const appName of restApps) {
    run("tmux", [
      "split-window",
      "-d",
      "-t",
      `${tmuxSession}:${splitWindowName}`,
      "-v",
      buildTailPaneCommand({ root, sessionOverride, appName, lines }),
    ]);
    run("tmux", ["select-layout", "-t", `${tmuxSession}:${splitWindowName}`, "tiled"]);
  }

  run("tmux", ["select-window", "-t", `${tmuxSession}:${splitWindowName}`]);
}

function getAttachEnv() {
  const term = String(process.env.TERM || "").trim();
  if (!term || term === "dumb") {
    return { ...process.env, TERM: "xterm-256color" };
  }
  return process.env;
}

function attachTmuxSession(tmuxSession) {
  run("tmux", ["attach-session", "-t", tmuxSession], {
    stdio: "inherit",
    env: getAttachEnv(),
  });
}

function enableTmuxMouse(tmuxSession) {
  run("tmux", ["set-option", "-t", tmuxSession, "mouse", "on"]);
}

function dieWithUsage(message, usageText, code = 1) {
  process.stderr.write(`${message}\n\n${usageText}\n`);
  process.exit(code);
}

async function main() {
  const parsed = parseArgs(process.argv.slice(2));
  const root = getWorktreeRoot(process.cwd());
  const sessionId = sessionNameFromPath(root);
  const tmuxSession = `dev-e2e-${sessionId}`;
  const { loaded: appsModule, configPath } = await loadAppsModule(root);
  const configFactory = getConfigFactory(appsModule, configPath);
  const baseUsageText = usage();

  if (parsed.help) {
    process.stdout.write(`${baseUsageText}\n`);
    return;
  }

  if (!parsed.command) {
    process.stderr.write(`${baseUsageText}\n`);
    process.exit(1);
  }

  const validCommands = new Set([
    "start",
    "restart",
    "stop",
    "attach",
    "logs",
    "tail",
    "split-attach",
    "tool",
    "cmd",
  ]);
  if (!validCommands.has(parsed.command)) {
    process.stderr.write(`Error: unknown command "${parsed.command}"\n\n${baseUsageText}\n`);
    process.exit(1);
  }

  const cfg = resolveRuntimeConfig(configFactory, configPath, sessionId);
  const apps = cfg.apps;
  const tools = cfg.tools && typeof cfg.tools === "object" ? cfg.tools : {};
  const appNames = Object.keys(apps).sort();
  const toolNames = Object.keys(tools).sort();
  const appEntries = appNames.map((name) => ({
    name,
    description: getItemDescription(apps[name]),
  }));
  const toolEntries = toolNames.map((name) => ({
    name,
    description: getItemDescription(tools[name]),
  }));
  const usageText = usage(appEntries, toolEntries);

  const isStartLike = parsed.command === "start" || parsed.command === "restart";
  if (!isStartLike && (parsed.attachRequested || parsed.splitAttachRequested)) {
    die("Error: --attach and --split-attach are only supported for start/restart.");
  }
  if (parsed.attachRequested && parsed.splitAttachRequested) {
    die("Error: --attach and --split-attach are mutually exclusive.");
  }
  if (
    parsed.linesOverride !== null &&
    !(
      parsed.command === "logs" ||
      parsed.command === "tail" ||
      parsed.command === "split-attach" ||
      (isStartLike && parsed.splitAttachRequested)
    )
  ) {
    die(
      "Error: --lines is only supported for logs, tail, split-attach, or start/restart with --split-attach."
    );
  }
  if (parsed.untilMarker !== null && parsed.command !== "tail") {
    die("Error: --until-marker is only supported for tail.");
  }
  if (parsed.untilTimeoutSeconds !== null && parsed.command !== "tail") {
    die("Error: --until-timeout is only supported for tail.");
  }

  if (parsed.command === "tool") {
    const toolName = parsed.app;
    if (!toolName) {
      process.stderr.write(`${usageText}\n`);
      process.exit(2);
    }

    if (!Object.prototype.hasOwnProperty.call(tools, toolName)) {
      dieWithUsage(`Error: unknown tool "${toolName}"`, usageText);
    }

    const toolCommand = resolveToolCommand(toolName, tools[toolName], parsed.commandArgs);
    const toolCommandWithPath = withInheritedPath(toolCommand);

    process.stdout.write(`Running tool "${toolName}": ${toolCommand}\n`);
    const shellPath = process.env.SHELL || "/bin/zsh";
    try {
      run(shellPath, ["-lc", toolCommandWithPath], { cwd: root, stdio: "inherit" });
    } catch (error) {
      die(`Error: tool "${toolName}" failed: ${error.message}`);
    }
    return;
  }

  if (parsed.command === "cmd") {
    if (!parsed.app) {
      process.stderr.write(`${usageText}\n`);
      process.exit(2);
    }

    if (!Object.prototype.hasOwnProperty.call(apps, parsed.app)) {
      dieWithUsage(`Error: unknown app "${parsed.app}"`, usageText);
    }

    const startCommand = resolveStartCommand(parsed.app, apps[parsed.app]);
    const wrappedCommand = `cd ${shellQuote(root)} && ${startCommand}`;
    process.stdout.write(`${wrappedCommand}\n`);
    return;
  }

  if (parsed.command === "start" || parsed.command === "restart") {
    const isRestart = parsed.command === "restart";
    if (!parsed.app) {
      process.stderr.write(`${usageText}\n`);
      process.exit(2);
    }

    ensureTmuxInstalled();
    let sessionExists = tmuxSessionExists(tmuxSession);
    let defaultAttachWindow = "";

    if (parsed.app === "all") {
      if (appNames.length === 0) {
        die("Error: no apps are configured in dev.config.js.");
      }

      if (!isRestart && sessionExists) {
        const existingWindows = appNames.filter((name) => tmuxWindowExists(tmuxSession, name));
        if (existingWindows.length > 0) {
          die(
            `Error: cannot start all because these windows already exist in session "${tmuxSession}": ${existingWindows.join(", ")}.`
          );
        }
      }

      if (isRestart && sessionExists) {
        for (const name of appNames) {
          if (tmuxWindowExists(tmuxSession, name)) {
            run("tmux", ["kill-window", "-t", `${tmuxSession}:${name}`], {
              allowFailure: true,
            });
          }
        }
        sessionExists = tmuxSessionExists(tmuxSession);
      }

      const startEntries = appNames.map((name) => {
        const startCommand = resolveStartCommand(name, apps[name]);
        return {
          name,
          wrappedCommand: `cd ${shellQuote(root)} && ${startCommand}`,
        };
      });

      if (sessionExists) {
        for (const entry of startEntries) {
          run("tmux", [
            "new-window",
            "-d",
            "-t",
            tmuxSession,
            "-n",
            entry.name,
            entry.wrappedCommand,
          ]);
        }
      } else {
        const [firstEntry, ...restEntries] = startEntries;
        run("tmux", [
          "new-session",
          "-d",
          "-s",
          tmuxSession,
          "-n",
          firstEntry.name,
          firstEntry.wrappedCommand,
        ]);
        for (const entry of restEntries) {
          run("tmux", [
            "new-window",
            "-d",
            "-t",
            tmuxSession,
            "-n",
            entry.name,
            entry.wrappedCommand,
          ]);
        }
      }

      process.stdout.write(
        `${isRestart ? "Restarted" : "Started"} apps ${appNames.join(", ")} in session "${tmuxSession}".\n`
      );
      for (const entry of startEntries) {
        process.stdout.write(`- ${entry.name}: ${entry.wrappedCommand}\n`);
      }
      defaultAttachWindow = appNames[0];
    } else {
      if (!Object.prototype.hasOwnProperty.call(apps, parsed.app)) {
        dieWithUsage(`Error: unknown app "${parsed.app}"`, usageText);
      }

      const startCommand = resolveStartCommand(parsed.app, apps[parsed.app]);
      const wrappedCommand = `cd ${shellQuote(root)} && ${startCommand}`;

      if (!isRestart && sessionExists && tmuxWindowExists(tmuxSession, parsed.app)) {
        die(`Error: window "${parsed.app}" already exists in session "${tmuxSession}".`);
      }

      if (isRestart && sessionExists && tmuxWindowExists(tmuxSession, parsed.app)) {
        run("tmux", ["kill-window", "-t", `${tmuxSession}:${parsed.app}`], {
          allowFailure: true,
        });
        sessionExists = tmuxSessionExists(tmuxSession);
      }

      if (sessionExists) {
        run("tmux", ["new-window", "-d", "-t", tmuxSession, "-n", parsed.app, wrappedCommand]);
      } else {
        run("tmux", ["new-session", "-d", "-s", tmuxSession, "-n", parsed.app, wrappedCommand]);
      }

      process.stdout.write(
        `${isRestart ? "Restarted" : "Started"} app "${parsed.app}" in session "${tmuxSession}" (window "${parsed.app}").\n`
      );
      process.stdout.write(`Command: ${wrappedCommand}\n`);
      defaultAttachWindow = parsed.app;
    }

    enableTmuxMouse(tmuxSession);

    if (parsed.splitAttachRequested) {
      const lines = resolveLineCount(parsed.linesOverride);
      openSplitAttachWindow({
        root,
        sessionOverride: null,
        tmuxSession,
        appNames,
        lines,
      });
      attachTmuxSession(tmuxSession);
      return;
    }

    if (parsed.attachRequested) {
      if (defaultAttachWindow) {
        run("tmux", ["select-window", "-t", `${tmuxSession}:${defaultAttachWindow}`], {
          allowFailure: true,
        });
      }
      attachTmuxSession(tmuxSession);
      return;
    }

    return;
  }

  if (parsed.command === "stop") {
    if (!parsed.app) {
      process.stderr.write(`${usageText}\n`);
      process.exit(2);
    }

    ensureTmuxInstalled();

    if (parsed.app !== "all" && !Object.prototype.hasOwnProperty.call(apps, parsed.app)) {
      dieWithUsage(`Error: unknown app "${parsed.app}"`, usageText);
    }

    const sessionExists = tmuxSessionExists(tmuxSession);
    if (!sessionExists) {
      die(`Error: session "${tmuxSession}" does not exist.`);
    }

    if (parsed.app === "all") {
      run("tmux", ["kill-session", "-t", tmuxSession]);
      process.stdout.write(`Stopped session "${tmuxSession}".\n`);
      return;
    }

    if (!tmuxWindowExists(tmuxSession, parsed.app)) {
      die(`Error: window "${parsed.app}" does not exist in session "${tmuxSession}".`);
    }

    run("tmux", ["kill-window", "-t", `${tmuxSession}:${parsed.app}`]);
    process.stdout.write(`Stopped app "${parsed.app}" in session "${tmuxSession}".\n`);
    return;
  }

  if (parsed.command === "logs") {
    ensureAppTarget({
      appName: parsed.app,
      apps,
      usageText,
      tmuxSession,
    });

    const lines = resolveLineCount(parsed.linesOverride);
    let snapshot = "";
    try {
      snapshot = captureWindowLogs(tmuxSession, parsed.app, lines);
    } catch (error) {
      die(`Error: ${error.message}`);
    }

    if (snapshot) {
      process.stdout.write(`${snapshot}\n`);
    }
    return;
  }

  if (parsed.command === "tail") {
    ensureAppTarget({
      appName: parsed.app,
      apps,
      usageText,
      tmuxSession,
    });

    const lines = resolveLineCount(parsed.linesOverride);
    const untilMarker = parsed.untilMarker;
    const untilTimeoutSeconds = parsed.untilTimeoutSeconds;
    let previousLines = [];
    let timer = null;
    let timeoutTimer = null;
    let tailStopped = false;

    const stopTail = (code = 0, message = "") => {
      if (tailStopped) return;
      tailStopped = true;
      if (timer) clearInterval(timer);
      if (timeoutTimer) clearTimeout(timeoutTimer);
      if (message) {
        const out = code === 0 ? process.stdout : process.stderr;
        out.write(`${message}\n`);
      }
      process.exit(code);
    };

    try {
      const initialSnapshot = captureWindowLogs(tmuxSession, parsed.app, lines);
      if (initialSnapshot) {
        process.stdout.write(`${initialSnapshot}\n`);
        previousLines = initialSnapshot.split(/\r?\n/);
      }
      if (untilMarker && initialSnapshot.includes(untilMarker)) {
        stopTail(0);
        return;
      }
    } catch (error) {
      die(`Error: ${error.message}`);
    }

    if (untilTimeoutSeconds !== null) {
      const timeoutMs = Math.max(1, Math.round(untilTimeoutSeconds * 1000));
      timeoutTimer = setTimeout(() => {
        if (untilMarker) {
          stopTail(
            124,
            `Error: marker "${untilMarker}" was not found within ${untilTimeoutSeconds} seconds.`
          );
          return;
        }
        stopTail(0);
      }, timeoutMs);
    }

    timer = setInterval(() => {
      try {
        const snapshot = captureWindowLogs(tmuxSession, parsed.app, lines);
        const nextLines = snapshot ? snapshot.split(/\r?\n/) : [];
        const overlap = getOverlapCount(previousLines, nextLines);
        const appended = nextLines.slice(overlap);
        if (appended.length > 0) {
          process.stdout.write(`${appended.join("\n")}\n`);
        }
        previousLines = nextLines;
        if (untilMarker && snapshot.includes(untilMarker)) {
          stopTail(0);
        }
      } catch (error) {
        stopTail(1, `Error: ${error.message}`);
      }
    }, 1000);

    process.on("SIGINT", () => stopTail(0));
    process.on("SIGTERM", () => stopTail(0));
    return;
  }

  if (parsed.command === "split-attach") {
    if (parsed.app) {
      dieWithUsage("Error: split-attach does not take an app argument.", usageText);
    }

    ensureTmuxInstalled();

    if (!tmuxSessionExists(tmuxSession)) {
      die(`Error: session "${tmuxSession}" does not exist.`);
    }

    enableTmuxMouse(tmuxSession);
    const lines = resolveLineCount(parsed.linesOverride);
    openSplitAttachWindow({
      root,
      sessionOverride: null,
      tmuxSession,
      appNames,
      lines,
    });
    attachTmuxSession(tmuxSession);
    return;
  }

  if (parsed.command === "attach") {
    if (parsed.app) {
      dieWithUsage("Error: attach does not take an app argument.", usageText);
    }

    ensureTmuxInstalled();

    if (!tmuxSessionExists(tmuxSession)) {
      die(`Error: session "${tmuxSession}" does not exist.`);
    }

    enableTmuxMouse(tmuxSession);
    attachTmuxSession(tmuxSession);
    return;
  }

  process.stderr.write(`Error: unknown command "${parsed.command}"\n\n${usageText}\n`);
  process.exit(1);
}

main().catch((error) => {
  die(error && error.message ? error.message : String(error));
});
