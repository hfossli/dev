#!/usr/bin/env bash
set -euo pipefail

DEFAULT_REMOTE="origin"

CURRENT_BRANCH="$(git symbolic-ref --quiet --short HEAD || true)"
IS_DETACHED=0
if [ -z "$CURRENT_BRANCH" ]; then
  IS_DETACHED=1
  CURRENT_BRANCH="HEAD"
fi

UPSTREAM=""
if [ "$IS_DETACHED" -eq 0 ]; then
  UPSTREAM="$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || true)"
fi

if [ -z "$UPSTREAM" ] && [ "$IS_DETACHED" -eq 1 ]; then
  REMOTE_HEAD="$(git symbolic-ref --quiet "refs/remotes/$DEFAULT_REMOTE/HEAD" --short 2>/dev/null || true)"
  if [ -n "$REMOTE_HEAD" ]; then
    UPSTREAM="$REMOTE_HEAD"
    echo "HEAD is detached; using remote default branch $UPSTREAM."
  elif git show-ref --verify --quiet "refs/remotes/$DEFAULT_REMOTE/main"; then
    UPSTREAM="$DEFAULT_REMOTE/main"
    echo "HEAD is detached; using fallback branch $UPSTREAM."
  else
    echo "HEAD is detached and no $DEFAULT_REMOTE default branch could be determined."
    echo "Set $DEFAULT_REMOTE/HEAD or check out a branch, then run again."
    exit 1
  fi
fi

if [ -z "$UPSTREAM" ]; then
  if git show-ref --verify --quiet "refs/remotes/$DEFAULT_REMOTE/$CURRENT_BRANCH"; then
    UPSTREAM="$DEFAULT_REMOTE/$CURRENT_BRANCH"
    echo "No upstream configured for $CURRENT_BRANCH; using $UPSTREAM."
  else
    echo "No upstream configured for $CURRENT_BRANCH and no $DEFAULT_REMOTE/$CURRENT_BRANCH found."
    echo "Set one with: git branch --set-upstream-to <remote>/<branch> $CURRENT_BRANCH"
    exit 1
  fi
fi

REMOTE="${UPSTREAM%%/*}"
UPSTREAM_BRANCH="${UPSTREAM#*/}"

echo "Fetching $REMOTE/$UPSTREAM_BRANCH..."
git fetch "$REMOTE" "$UPSTREAM_BRANCH"

echo "Rebasing $CURRENT_BRANCH onto $UPSTREAM (preferring remote changes on conflicts)..."
# During rebase conflicts, "ours" is the upstream branch and "theirs" is the replayed local commit.
git rebase --autostash -X ours "$UPSTREAM"

echo ""
echo "Pull completed."
echo "Current branch: $CURRENT_BRANCH"
echo "Rebased onto: $UPSTREAM"
